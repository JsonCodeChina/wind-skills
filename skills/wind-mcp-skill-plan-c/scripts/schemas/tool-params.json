            "type": "string",
            "enum": ["English", "中文"],
            "description": "默认 中文"
          }
        },
        "required": ["question"]
      }
    },
    "get_stock_fundamentals": {
      "description": "A股盈利、资产负债、利润、现金流、增长率",
