          },
          "lang": {
            "type": "string",
            "enum": ["English", "中文"],
            "description": "默认 中文"
          }
        },
        "required": ["question"]
      }
    },
    "get_stock_technicals": {
      "description": "A股 MACD、KDJ、RSI、BOLL、融资融券、龙虎榜",
      "params": {
        "type": "object",
        "properties": {
          "question": {
