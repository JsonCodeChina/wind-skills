{
  "schema_version": 1,
  "description": "Data-driven parameter validation rules used by scripts/cli.mjs before calling Wind MCP tools.",
  "basic": {
    "string_keys": [
      "question",
      "query",
      "windcode",
      "indexes",
      "executionMode",
      "observation"
    ],
    "no_whitespace_keys": [
      "query"
    ],
    "date_keys": [
      "begin_date",
      "end_date",
      "beginDate",
      "endDate",
      "date",
      "tradeDate"
    ],
    "single_target_keys": [
      "windcode"
    ]
  },
  "tool_rules": [
    {
      "name": "kline",
      "label": "K 线",
      "tools": [
        "get_stock_kline",
        "get_fund_kline",
        "get_index_kline"
      ],
      "required": [
        "windcode",
        "begin_date",
        "end_date"
      ],
      "enum_fields": {
        "period": {
          "values_from": "normalization.kline_periods",
          "message": "字段 'period' 只能是 ${values}，日 K 请传 '10'"
        },
        "aftime": {
          "values": [
            "0",
            "1"
          ],
          "message": "字段 'aftime' 只能是 '0' 或 '1'"
        },
        "issusp": {
          "values": [
            "0",
            "1"
          ],
          "message": "字段 'issusp' 只能是 '0' 或 '1'"
        }
      }
    },
    {
      "name": "economic_edb",
      "label": "宏观 EDB",
      "tools": [
        "natural_language_get_edb_data"
      ],
      "allowed": [
        "executionMode",
        "question",
        "beginDate",
        "endDate",
        "observation"
      ],
      "required": [
        "executionMode",
        "question"
      ],
      "enum_fields": {
        "executionMode": {
          "values": [
            "search",
            "fetch",
            "searchFetch",
            "仅搜索",
            "仅提数",
            "搜索并提数"
          ],
          "message": "字段 'executionMode' 只能是 search/fetch/searchFetch 或 仅搜索/仅提数/搜索并提数"
        }
      },
      "paired": [
        [
          "beginDate",
          "endDate"
        ]
      ],
      "mutually_exclusive": [
        [
          "observation",
          "beginDate"
        ],
        [
          "observation",
          "endDate"
        ]
      ],
      "ordered_dates": [
        [
          "beginDate",
          "endDate"
        ]
      ],
      "patterns": {
        "observation": {
          "pattern": "^(\\d+|all)$",
          "message": "字段 'observation' 只能是数字字符串或 'all'"
        }
      },
      "required_one_of_when": [
        {
          "field": "executionMode",
          "values": [
            "fetch",
            "searchFetch",
            "仅提数",
            "搜索并提数"
          ],
          "one_of": [
            [
              "observation"
            ],
            [
              "beginDate",
              "endDate"
            ]
          ],
          "message": "executionMode 为 fetch/searchFetch 时，必须显式提供 beginDate/endDate 或 observation"
        }
      ]
    }
  ]
}
